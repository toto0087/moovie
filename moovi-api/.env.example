PORT=3001
FRONTEND_URL=http://localhost:5173

# Producción (Render): pegá la Internal Database URL y alcanza.
DATABASE_URL=
# Local (Postgres): variables sueltas (se ignoran si DATABASE_URL está seteada)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=moovi_db
# Local: vacío. Render con External URL: DB_SSL=true (con Internal URL no hace falta)
DB_SSL=

JWT_SECRET=change_this_to_a_random_secret
JWT_EXPIRES_IN=7d

# Obtenerlo de https://www.themoviedb.org/settings/api → Read Access Token
TMDB_ACCESS_TOKEN=
TMDB_COUNTRY=AR

# Chatbot (Gemini). Key gratis en https://aistudio.google.com/apikey
GEMINI_API_KEY=
